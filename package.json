{
  "name": "codex-mobile-terminal",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Browser-based multi-session Codex terminal for Windows and macOS.",
  "scripts": {
    "setup": "node ./scripts/setup.mjs",
    "start": "node ./src/server.js",
    "build": "npm run web:build",
    "web:build": "vite build --config ./web/vite.config.js",
    "web:dev": "vite --config ./web/vite.config.js",
    "test": "npm run test:backend",
    "test:backend": "npm run test:backend:all",
    "test:backend:all": "node --test --test-concurrency=1 tests/*.test.js",
    "test:backend:http": "node --test --test-concurrency=1 tests/koa-app.test.js tests/ws.test.js",
    "test:backend:session": "node --test --test-concurrency=1 tests/session-manager.test.js",
    "dev:up": "bash ./scripts/dev-up.sh",
    "dev:down": "bash ./scripts/dev-down.sh",
    "server:dev": "node --watch ./src/server.js",
    "dev:hot": "concurrently -k -n server,web \"npm:server:dev\" \"npm:web:dev\"",
    "check": "node --check ./src/server.js && node --check ./src/config.js && node --check ./src/sessionManager.js && node --check ./scripts/service.mjs && node --check ./scripts/launchd/manage.mjs && npm run web:build",
    "pm2:dev": "pm2 startOrReload ecosystem.config.cjs --only codex-mobile-terminal-dev --update-env",
    "pm2:prod": "pm2 startOrReload ecosystem.config.cjs --only codex-mobile-terminal --update-env",
    "pm2:stop": "pm2 delete codex-mobile-terminal codex-mobile-terminal-dev",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs codex-mobile-terminal --lines 120",
    "service:start": "node ./scripts/service.mjs start --mode prod",
    "service:start:dev": "node ./scripts/service.mjs start --mode dev",
    "service:restart": "node ./scripts/service.mjs restart --mode prod",
    "service:restart:dev": "node ./scripts/service.mjs restart --mode dev",
    "service:stop": "node ./scripts/service.mjs stop",
    "service:status": "node ./scripts/service.mjs status",
    "service:list": "node ./scripts/service.mjs list",
    "service:list:json": "node ./scripts/service.mjs list --json",
    "service:logs": "node ./scripts/service.mjs logs --mode prod",
    "service:logs:dev": "node ./scripts/service.mjs logs --mode dev",
    "service:resurrect": "node ./scripts/service.mjs resurrect --mode prod",
    "launchd:render": "node ./scripts/launchd/manage.mjs render",
    "launchd:install": "node ./scripts/launchd/manage.mjs install",
    "launchd:uninstall": "node ./scripts/launchd/manage.mjs uninstall",
    "launchd:list": "node ./scripts/launchd/manage.mjs list",
    "dev": "npm run dev:hot",
    "prod": "npm run service:start"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.2.3",
    "highlight.js": "^11.11.1",
    "koa": "^2.16.4",
    "markdown-it": "^14.1.1",
    "node-pty": "^1.2.0-beta.12",
    "vue": "^3.5.31",
    "vue-router": "^4.6.4",
    "ws": "^8.18.3",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "concurrently": "^9.2.1",
    "pm2": "^6.0.8",
    "vite": "^8.0.3"
  }
}
